NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=debug
LOG_FORMAT=pretty
CORS_ORIGINS=http://localhost:5173
SHUTDOWN_TIMEOUT_MS=10000
MONGODB_URI=mongodb://127.0.0.1:27017/finpay
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
JWT_ISSUER=finpay-api
JWT_AUDIENCE=finpay-client
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
EMAIL_VERIFICATION_TOKEN_TTL=24h
BCRYPT_ROUNDS=12
PASSWORD_RESET_TTL_MINUTES=15
AUTH_COOKIE_NAME=finpay_refresh
AUTH_COOKIE_SECURE=false
PUBLIC_APP_URL=http://localhost:5173
ADMIN_EMAIL=your-admin@example.com
ADMIN_PASSWORD=your-admin-password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_MOBILE=9999999999999
